# L2Journey Docker Compose - copy to .env and adjust
# Database
MYSQL_ROOT_PASSWORD=l2j
MYSQL_DATABASE=l2journey
MYSQL_USER=l2j
MYSQL_PASSWORD=l2j
MYSQL_PORT=3306

# Ports (host)
LOGIN_PORT=2106
GAME_PORT=7777
LOGIN_DEBUG_PORT=5006
GAME_DEBUG_PORT=5005

# Optional: phpMyAdmin (local dev only). Start with: docker compose --profile pma up -d
# Binds to 127.0.0.1 only. Uses MYSQL_USER / MYSQL_PASSWORD for auto-login to host db.
PHPMYADMIN_PORT=8080

# Optional: JVM options (defaults from Dockerfiles)
# L2J_LOGIN_OPTS=-Xms128m -Xmx256m
# L2J_GAME_OPTS=-Xms1g -Xmx2g

# Optional: enable remote debugging (JDWP) from Cursor/VS Code.
# Keep suspend=n so services start normally without waiting for debugger attach.
# L2J_LOGIN_OPTS=-Xms128m -Xmx256m -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5006
# L2J_GAME_OPTS=-Xms2g -Xmx4g -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005
